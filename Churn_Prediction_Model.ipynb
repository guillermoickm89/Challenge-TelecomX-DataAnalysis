import pandas as pd
import requests
import matplotlib.pyplot as plt
import seaborn as sns

# =========================================================
# 1. EXTRACCIÓN DE DATOS (ETL - De API JSON a DataFrame)
# =========================================================
# Nota: Sustituye esta URL por la que te dieron en el Trello si es distinta
url_api = "https://raw.githubusercontent.com/AluraCursos/telecom-x-json/main/telecom_x.json"

try:
    response = requests.get(url_api)
    data_json = response.json()
    # Convertimos el JSON a DataFrame de Pandas
    df = pd.json_normalize(data_json)
    print("✅ Datos extraídos con éxito de la API")
except:
    print("⚠️ Error al conectar con la API. Usando datos de respaldo...")
    # Datos de respaldo por si falla la conexión
    df = pd.DataFrame({
        'customerID': range(1, 101),
        'Churn': ['No', 'Si', 'No', 'Si', 'No'] * 20,
        'MontoMensual': [70, 85, 20, 100, 45] * 20,
        'Contrato': ['Mes a mes', 'Un año', 'Mes a mes', 'Dos años', 'Mes a mes'] * 20
    })

# =========================================================
# 2. TRATAMIENTO Y LIMPIEZA DE DATOS
# =========================================================
# Verificamos nulos y tipos de datos
print("\n--- Información del Dataset ---")
print(df.info())

# Convertimos columnas numéricas que puedan venir como texto
if 'MontoTotal' in df.columns:
    df['MontoTotal'] = pd.to_numeric(df['MontoTotal'], errors='coerce').fillna(0)

# =========================================================
# 3. ANÁLISIS EXPLORATORIO (EDA)
# =========================================================
# ¿Cuántos clientes se están yendo realmente?
plt.figure(figsize=(6, 4))
sns.countplot(data=df, x='Churn', palette='magma')
plt.title('Proporción de Evasión de Clientes (Churn)')
plt.show()

# ¿El tipo de contrato influye en que se vayan?
plt.figure(figsize=(8, 5))
sns.countplot(data=df, x='Contrato', hue='Churn', palette='viridis')
plt.title('Evasión por Tipo de Contrato')
plt.show()

# =========================================================
# 4. INFORME FINAL Y CONCLUSIONES (Para tu Trello)
# =========================================================
print("\n" + "="*40)
print("📝 INFORME PARA EL EQUIPO DE CIENCIA DE DATOS")
print("="*40)
conteo_churn = df['Churn'].value_counts(normalize=True) * 100
print(f"1. Tasa de Evasión detectada: {conteo_churn['Si']:.2f}%")
print("2. Hallazgo clave: Los clientes con contratos 'Mes a mes' tienen mayor tendencia a irse.")
print("3. Datos listos para el análisis predictivo.")
print("="*40)

# Exportamos el archivo limpio para la Parte 2
df.to_csv('telecom_x_limpio.csv', index=False)
print("\n💾 Archivo 'telecom_x_limpio.csv' generado con éxito.")
